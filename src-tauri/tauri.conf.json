{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loudio",
  "version": "0.1.0",
  "identifier": "com.lexprotech.loudio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/runtime/output/**",
          "$APPLOCALDATA/runtime/output/**",
          "$RUNTIME/output/**",
          "$HOME/Library/Application Support/com.lexprotech.loudio/runtime/output/**"
        ]
      }
    },
    "windows": [
      {
        "title": "Loudio",
        "width": 1200,
        "height": 820,
        "resizable": true,
        "transparent": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "licenseFile": "../LICENSE",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "infoPlist": "Info.plist"
    }
  }
}
